Algoritmo propinas
	Escribir "Introduce el total de la cuenta: "
	Leer total
	Escribir "Introduce el porcentaje de propina (por ejemplo, 15 para 15%): "
	Leer porcentaje
	
	propina = total * (porcentaje / 100)
	totalConPropina = total + propina
	
	Escribir "Monto de la propina: ", propina
	Escribir "Total a pagar: ", totalConPropina


FinAlgoritmo
