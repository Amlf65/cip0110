Algoritmo dia_semana
	Escribir "Introduce un número del 1 al 7: "
	Leer numero
	
	Segun numero Hacer
		Caso 1:
			dia = "Lunes"
		Caso 2:
			dia = "Martes"
		Caso 3:
			dia = "Miércoles"
		Caso 4:
			dia = "Jueves"
		Caso 5:
			dia = "Viernes"
		Caso 6:
			dia = "Sábado"
		Caso 7:
			dia = "Domingo"
		De Otro Modo:
			dia = "Número inválido"
	FinSegun
	
	Escribir "El día correspondiente es: ", dia

FinAlgoritmo
