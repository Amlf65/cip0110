Algoritmo Ejercicio07
	//declaraciones
	var_ladolargo<-0;
	var_ladocorto<-0;
	//Instrucciones
	Escribir "Instroducir lado largo (en cm)";
	leer var_ladolargo
	Escribir "Instroducir lado corto (en cm)";
	leer var_ladocorto
	
	Escribir "El área es : " var_ladocorto*var_ladolargo " centímetros cuadrados"
	
FinAlgoritmo
